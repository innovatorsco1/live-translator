# ============================================================
# Live Translator – Environment Variables
#
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# OpenAI
# Required. Used by the server-side translation service.
# Obtain a key at https://platform.openai.com/account/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# ------------------------------------------------------------
# Server ports
# PORT     – Next.js HTTP server (default: 3000)
# WS_PORT  – Standalone WebSocket server (default: 3001)
# ------------------------------------------------------------
PORT=3000
WS_PORT=3001

# ------------------------------------------------------------
# Node environment
# Set to 'production' when deploying.
# ------------------------------------------------------------
NODE_ENV=development
